{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        // editor
        {
            "label": "editor [debug]",
            "options": {
                "cwd": "${workspaceFolder}/../../godot"
            },
            "type": "shell",
            "command": "scons",
            "args": [
                "platform=windows",
                "bits=64",
                "target=editor",
                "custom_modules=../ppgame/src",// todo
                "dev_build=yes",
                "debug_symbols=yes"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },

        // game
        {
            "label": "game [debug]",
            "type": "shell",
            "command": "scons",
            "args": [
                "platform=windows",
                "bits=64",
                "target=editor",
                "dev_build=yes",
                "debug_symbols=yes"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },

		// editor&game
		{
			"label": "editor&game [debug]",
			"dependsOn": ["editor [debug]", "game [debug]"]
		}
    ]
}
