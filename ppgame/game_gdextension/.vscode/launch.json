{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "editor [debug]",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/../../godot/bin/godot.windows.editor.dev.x86_64.exe",
            "args": [
                "--path", "${workspaceFolder}/../project",
                "--editor"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "internalConsole",
            "preLaunchTask": "editor&game [debug]"
        },
        {
            "name": "attach game",
            "type": "cppvsdbg",
            "request": "attach",
            "processId":"${command:pickProcess}"
        }
    ]
}
