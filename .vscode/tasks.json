{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "debug editor",
            "options": {
                "cwd": "${workspaceFolder}/godot"
            },
            "type": "shell",
            "command": "scons",
            "args": [
                "platform=windows",
                "bits=64",
                "target=editor",
                "custom_modules=../ppgame",
                "dev_build=yes",
                "debug_symbols=yes",
                "vsproj=yes",
                "compiledb=yes",
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
    ]
}