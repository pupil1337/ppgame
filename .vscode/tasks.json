{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        // godot
        {
            "label": "godot editor [debug]",
            "options": {
                "cwd": "${workspaceFolder}/godot"
            },
            "type": "shell",
            "command": "scons",
            "args": [
                "platform=windows",
                "bits=64",
                "target=editor",
                "dev_build=yes",
                "debug_symbols=yes"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },

        // ppgame
        {
            "label": "ppgame editor [debug]",
            "options": {
                "cwd": "${workspaceFolder}/ppgame/src"
            },
            "type": "shell",
            "command": "scons",
            "args": [
                "platform=windows",
                "bits=64",
                "target=editor",
                "dev_build=yes",
                "debug_symbols=yes"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        }
    ]
}